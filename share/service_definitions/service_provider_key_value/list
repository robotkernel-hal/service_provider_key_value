datatypes:
  service_provider_key_value/key_name: 
    fields: 
      key: { type: uint32_t }
      name: { type: string }
services:
  service_provider_key_value/list:
    response:
      entries: { type: service_provider_key_value/key_name, array: true }
      error_message: { type: string, default: "no error" }
