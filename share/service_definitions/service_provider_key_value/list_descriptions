datatypes:
  - name: service_provider_key_value/description
    fields:  
      - { name: key, type: uint32_t }
      - { name: description, type: string }
      - { name: unit, type: string }
      - { name: default_value, type: string }
      - { name: format, type: string }
      - { name: read_only, type: uint8_t }
services:
  - name: service_provider_key_value/list_descriptions
    response:
      - { name: entries, type: service_provider_key_value/description, array: true }
      - { name: error_message, type: string, default: "no error" }
