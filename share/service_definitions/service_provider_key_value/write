datatypes:
  service_provider_key_value/key_value: 
    fields:
      key: { type: uint32_t }
      value: { type: string } 
services:
  service_provider_key_value/write:
    request:
      entries: { type: service_provider_key_value/key_value, array: true }
    response:
      error_message: { type: string, default: "no error" }
